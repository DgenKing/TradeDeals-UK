---
import Layout from '../layouts/Layout.astro';

const categories = [
  { slug: 'power_tools', name: 'Power Tools', icon: '🔧', description: 'Drills, saws, sanders, grinders, and more', count: 156 },
  { slug: 'hand_tools', name: 'Hand Tools', icon: '🛠️', description: 'Hammers, screwdrivers, pliers, wrenches', count: 89 },
  { slug: 'building_materials', name: 'Building Materials', icon: '🧱', description: 'Plasterboard, insulation, bricks, cement', count: 234 },
  { slug: 'plumbing', name: 'Plumbing', icon: '🚿', description: 'Pipes, fittings, valves, taps, showers', count: 67 },
  { slug: 'electrical', name: 'Electrical', icon: '💡', description: 'Wire, cable, switches, sockets, lights', count: 45 },
  { slug: 'paint_decorating', name: 'Paint & Decorating', icon: '🎨', description: 'Paints, varnishes, wallpapers, brushes', count: 78 },
  { slug: 'garden_outdoor', name: 'Garden & Outdoor', icon: '🌿', description: 'Fencing, patio, decking, plants', count: 34 },
  { slug: 'hardware', name: 'Hardware', icon: '🔩', description: 'Screws, bolts, hinges, handles, locks', count: 123 },
];

function formatCategory(slug: string): string {
  return slug.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---

<Layout title="Categories - Trade Deals UK">
  <div class="bg-primary-700 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-white mb-4">Browse by Category</h1>
      <p class="text-primary-100 text-lg">Find deals across different trade categories</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {categories.map((cat) => (
        <a href={`/?category=${cat.slug}`} class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
          <div class="flex items-start justify-between mb-4">
            <span class="text-4xl">{cat.icon}</span>
            <span class="bg-primary-100 text-primary-700 px-2 py-1 rounded text-sm font-medium">
              {cat.count} deals
            </span>
          </div>
          <h2 class="text-xl font-bold text-gray-900 mb-2">{cat.name}</h2>
          <p class="text-gray-600 text-sm">{cat.description}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
