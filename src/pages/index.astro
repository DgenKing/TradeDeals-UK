---
import Layout from '../layouts/Layout.astro';

// Sample demo data - replace with real data from Neon DB when connected
const sampleDeals = [
  { id: 1, product_name: 'DeWalt 18V XR Drill Driver', retailer_name: 'Toolstation', retail_price: 89.99, original_price: 119.99, savings_amount: 30, savings_percent: 25, category: 'power_tools', image_url: '' },
  { id: 2, product_name: 'Makita Circular Saw 190mm', retailer_name: 'Wickes', retail_price: 74.99, original_price: 99.99, savings_amount: 25, savings_percent: 25, category: 'power_tools', image_url: '' },
  { id: 3, product_name: 'Stanley FatMax Tape Measure 5m', retailer_name: 'Screwfix', retail_price: 12.99, original_price: 18.99, savings_amount: 6, savings_percent: 32, category: 'hand_tools', image_url: '' },
  { id: 4, product_name: 'British Gypsum Plasterboard 12.5mm', retailer_name: 'Travis Perkins', retail_price: 8.50, original_price: 11.00, savings_amount: 2.50, savings_percent: 23, category: 'building_materials', image_url: '' },
  { id: 5, product_name: 'Bosch Angle Grinder 18V', retailer_name: 'Toolstation', retail_price: 59.99, original_price: 79.99, savings_amount: 20, savings_percent: 25, category: 'power_tools', image_url: '' },
  { id: 6, product_name: 'John Guest Speedfit Pipe 15mm', retailer_name: 'City Plumbing', retail_price: 2.50, original_price: 3.25, savings_amount: 0.75, savings_percent: 23, category: 'plumbing', image_url: '' },
  { id: 7, product_name: 'Dulux Trade Matt Emulsion 5L', retailer_name: 'B&Q TradePoint', retail_price: 24.99, original_price: 34.99, savings_amount: 10, savings_percent: 29, category: 'paint_decorating', image_url: '' },
  { id: 8, product_name: 'Forgefix M10 Stainless Washers Pack 200', retailer_name: 'Screwfix', retail_price: 4.99, original_price: 7.99, savings_amount: 3, savings_percent: 38, category: 'hardware', image_url: '' },
];

const categories = [
  { slug: 'power_tools', name: 'Power Tools', icon: '🔧' },
  { slug: 'hand_tools', name: 'Hand Tools', icon: '🛠️' },
  { slug: 'building_materials', name: 'Building Materials', icon: '🧱' },
  { slug: 'plumbing', name: 'Plumbing', icon: '🚿' },
  { slug: 'paint_decorating', name: 'Paint & Decorating', icon: '🎨' },
  { slug: 'hardware', name: 'Hardware', icon: '🔩' },
];

function getSavingsClass(percent?: number): string {
  if (!percent) return 'text-gray-500';
  if (percent >= 30) return 'text-deal-hot font-bold';
  if (percent >= 20) return 'text-deal-good font-semibold';
  return 'text-deal-ok';
}

function formatCategory(slug?: string): string {
  if (!slug) return '';
  return slug.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---

<Layout title="Trade Deals UK - Find the Best Discounts on Building Materials & Tools">
  <div class="bg-primary-700 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-white mb-4">Trade Deals UK</h1>
      <p class="text-primary-100 text-lg mb-8">Find the best discounts on building materials, power tools, and hardware</p>

      <!-- Search Form -->
      <form action="/" method="get" class="bg-white rounded-lg shadow-lg p-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <input
              type="text"
              name="q"
              placeholder="Search products..."
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
            />
          </div>
          <div>
            <select name="category" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500">
              <option value="">All Categories</option>
              {categories.map((cat) => (
                <option value={cat.slug}>{cat.icon} {cat.name}</option>
              ))}
            </select>
          </div>
          <button type="submit" class="bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 font-semibold">
            Search Deals
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Demo Notice -->
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-8">
      <p class="text-blue-700">
        <strong>Demo Mode:</strong> Browse sample deals. Connect a Neon database to see live data.
      </p>
    </div>

    <p class="text-gray-600 mb-6">{sampleDeals.length} sample deals shown</p>

    <!-- Deals Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {sampleDeals.map((deal) => (
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <div class="relative">
            <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
              <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            {deal.savings_percent >= 20 && (
              <div class="absolute top-2 right-2 bg-deal-hot text-white px-2 py-1 rounded-full text-sm font-bold">
                {deal.savings_percent}% OFF
              </div>
            )}
          </div>
          <div class="p-4">
            <p class="text-xs text-gray-500 mb-1">{deal.retailer_name}</p>
            <h3 class="font-semibold text-gray-900 mb-2 line-clamp-2">{deal.product_name}</h3>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="text-xl font-bold text-primary-600">£{deal.retail_price.toFixed(2)}</span>
              {deal.original_price && (
                <span class="text-sm text-gray-400 line-through">£{deal.original_price.toFixed(2)}</span>
              )}
            </div>
            <p class={`text-sm ${getSavingsClass(deal.savings_percent)}`}>
              Save £{deal.savings_amount.toFixed(2)} ({deal.savings_percent}% off)
            </p>
            <div class="mt-3 flex items-center justify-between">
              <span class="text-xs text-gray-500">{formatCategory(deal.category)}</span>
              <span class="bg-primary-100 text-primary-700 px-3 py-1 rounded text-sm">View Deal</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
