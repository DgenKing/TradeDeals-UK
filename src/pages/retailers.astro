---
import Layout from '../layouts/Layout.astro';

const retailers = [
  { name: 'Wickes', logo: 'W', color: 'bg-orange-500', description: 'Building materials, tools, and home improvement', count: 234 },
  { name: 'Toolstation', logo: 'T', color: 'bg-blue-600', description: 'Tools, hardware, and building supplies', count: 189 },
  { name: 'B&Q TradePoint', logo: 'BQ', color: 'bg-yellow-500', description: 'Trade counter and bulk orders', count: 156 },
  { name: 'Travis Perkins', logo: 'TP', color: 'bg-red-600', description: 'Professional building materials', count: 312 },
  { name: 'Jewsons', logo: 'J', color: 'bg-blue-800', description: 'Building and timber merchants', count: 178 },
  { name: 'City Plumbing', logo: 'CP', color: 'bg-cyan-600', description: 'Plumbing and heating supplies', count: 89 },
  { name: 'Homebase Trade', logo: 'HB', color: 'bg-red-500', description: 'Trade and professional range', count: 67 },
  { name: 'Screwfix', logo: 'S', color: 'bg-yellow-600', description: 'Tools and hardware specialist', count: 245 },
];
---

<Layout title="Retailers - Trade Deals UK">
  <div class="bg-primary-700 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-white mb-4">Browse by Retailer</h1>
      <p class="text-primary-100 text-lg">Find deals from top UK trade retailers</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {retailers.map((retailer) => (
        <a href={`/?retailer=${encodeURIComponent(retailer.name)}`} class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
          <div class="flex items-center gap-4 mb-4">
            <div class={`${retailer.color} text-white rounded-lg w-14 h-14 flex items-center justify-center font-bold text-lg`}>
              {retailer.logo}
            </div>
            <span class="bg-primary-100 text-primary-700 px-2 py-1 rounded text-sm font-medium">
              {retailer.count} deals
            </span>
          </div>
          <h2 class="text-xl font-bold text-gray-900 mb-2">{retailer.name}</h2>
          <p class="text-gray-600 text-sm">{retailer.description}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
